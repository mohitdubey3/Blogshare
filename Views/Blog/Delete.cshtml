@model Post

@{
    ViewData["Title"] = "Delete Post";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-body p-5">
                <h2 class="card-title mb-3">Delete Post</h2>
                <p class="text-muted mb-4">
                    Are you sure you want to delete <strong class="text-info">@Model.Title</strong> Post ?
                </p>

                <div class="alert alert-warning mb-4">
                    <strong>Warning!</strong> Deleting this post will permanently remove it from your blog.
                </div>

                <form asp-controller="Blog" asp-action="DeleteConfirm" method="post" class="mb-3">
                    <input asp-for="@Model.Id" hidden />
                    <button type="submit" class="btn btn-danger me-2">Delete Post</button>
                    <a asp-action="Index" asp-controller="Blog" class="btn btn-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>