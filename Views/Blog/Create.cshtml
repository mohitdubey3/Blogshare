@model PostViewModel

@{
    ViewData["Title"] = "Create Post";
}

<div class="row mb-4">
    <div class="col-6">
        <h2>@ViewData["Title"]</h2>
    </div>
    <div class="col-6 text-end">
        <a class="btn btn-secondary" asp-action="Index" asp-controller="Blog">Back to List</a>
    </div>
</div>

<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" asp-controller="Blog" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Posts.Title" class="form-label"></label>
                <input asp-for="Posts.Title" class="form-control" />
                <span asp-validation-for="Posts.Title" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Posts.CategoryId" class="form-label"></label>
                <select asp-for="Posts.CategoryId" asp-items="Model.Categories" class="form-control">
                    <option value="">Select Category</option>
                </select>
                <span asp-validation-for="Posts.CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Posts.Author" class="form-label"></label>
                <input asp-for="Posts.Author" class="form-control" />
                <span asp-validation-for="Posts.Author" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Posts.Content" class="form-label"></label>
                <textarea asp-for="Posts.Content" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Posts.Content" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="FeatureImage" class="form-label"></label>
                <input asp-for="FeatureImage" class="form-control" />
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Create</button>
                <a class="btn btn-secondary" asp-action="Index" asp-controller="Blog">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script src="https://cdn.tiny.cloud/1/8v7ap9no879e3vf48t9bipzno7dfbo8dgefvm9kgcttuz3nu/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>
    <script>
        tinymce.init({
            selector: 'textarea'
        });
    </script>
}