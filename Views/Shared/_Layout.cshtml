<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlogShare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-dark bg-dark navbar-toggleable-md border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Blog" asp-action="Index">BlogShare</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavDarkDropdown" aria-controls="navbarNavDarkDropdown" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNavDarkDropdown">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Blog" asp-action="Category">Category</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>

    </header>
    <main role="main" class="flex-shrink-0">
        <div class="content-wrapper">
            <div class="container my-5 py-2 fade-in">
                @RenderBody()
            </div>
        </div>
    </main>

   
            <footer class="bg-dark text-white pt-5 pb-4 mt-5">
                <div class="container text-center text-md-start">
                    <div class="row text-center text-md-start">

                        <div class="col-md-4 col-lg-4 col-xl-3 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-primary">Blog Share</h5>
                            <p class="text-white-50">
                                A platform dedicated to sharing ideas, stories, and expertise. Join our community of readers and creators to explore what matters most to you.
                            </p>
                        </div>

                        <div class="col-md-2 col-lg-2 col-xl-2 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-primary">Explore</h5>
                            <p><a class="text-white-50 text-decoration-none hover-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a></p>
                            <p><a class="text-white-50 text-decoration-none hover-link" asp-area="" asp-controller="Home" asp-action="About">About Us</a></p>
                            <p><a class="text-white-50 text-decoration-none hover-link" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a></p>
                        </div>

                        <div class="col-md-3 col-lg-2 col-xl-2 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-primary">Interests</h5>
                            <p><a class="text-white-50 text-decoration-none hover-link" asp-controller="Blog" asp-action="Index" asp-route-categoryId="1">Technology</a></p>
                            <p><a class="text-white-50 text-decoration-none hover-link" asp-controller="Blog" asp-action="Index" asp-route-categoryId="3">Lifestyle</a></p>
                            <p><a class="text-white-50 text-decoration-none hover-link" asp-controller="Blog" asp-action="Index" asp-route-categoryId="2">Health</a></p>
                        </div>

                        <div class="col-md-4 col-lg-3 col-xl-3 mx-auto mt-3">
                            <h5 class="text-uppercase mb-4 fw-bold text-primary">Follow Us</h5>
                            <div class="d-flex justify-content-center justify-content-md-start mb-4">
                                <a href="#" class="btn btn-outline-light btn-sm rounded-circle me-2"><i class="bi bi-twitter-x"></i></a>
                                <a href="https://github.com/mohitdubey3/" class="btn btn-outline-light btn-sm rounded-circle me-2"><i class="bi bi-github"></i></a>
                                <a href="#" class="btn btn-outline-light btn-sm rounded-circle me-2"><i class="bi bi-instagram"></i></a>
                                <a href="https://github.com/mohitdubey3/" class="btn btn-outline-light btn-sm rounded-circle"><i class="bi bi-linkedin"></i></a>
                            </div>
                            <p class="small text-white-50">Follow Us To Know About Our New Services</p>
                        </div>
                    </div>

                    <hr class="mb-4 opacity-25">

                    <div class="row align-items-center">
                        <div class="text-center text-md-start">
                            <p class="mb-0 text-white-50">
                                &copy; @DateTime.Now.Year <strong>Blog Share</strong>. All Rights Reserved.
                            </p>
                            <p class="float-end">By <strong>Mohit Dubey</strong></p>                       
                        </div>
                    </div>
                </div>
            </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
